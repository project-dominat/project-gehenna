command-description-feedback-add = Добавляет прототип окна обратной связи указанным клиентам и открывает окно, если у клиента его еще не было в списке.
command-description-feedback-remove = Убирает прототип окна обратной связи у указанных клиентов.

feedbackpopup-give-command-name = givefeedbackpopup
feedbackpopup-show-command-name = showfeedbackpopup
