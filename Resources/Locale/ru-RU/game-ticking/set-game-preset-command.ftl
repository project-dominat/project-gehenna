set-game-preset-decoy-error = Если указан аргумент 3, это должна быть допустимая предустановка. Не удалось найти пресет игры «{$preset}».

#set-game-preset-preset-set = Set game preset to "{$preset}"

set-game-preset-preset-set-finite = Установите предустановку игры на «{$preset}» для следующих раундов {$rounds}.

set-game-preset-preset-set-finite-with-decoy = Установите предустановку игры на «{$preset}» для следующих раундов {$rounds}, чтобы в лобби отображался {$decoy}.
